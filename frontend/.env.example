# API 服务地址（可选，默认 localhost）
VITE_LAYOUT_API_URL=http://localhost:8001
VITE_OCR_API_URL=http://localhost:8002

# PDF 解析并发数（默认 3）
VITE_PARSE_CONCURRENCY=3

# 公式识别 API（默认启用，返回 LaTeX）
VITE_USE_FORMULA_API=true
VITE_FORMULA_API_URL=http://192.168.3.10:8899

# 表格识别 API（默认启用，返回 HTML）
VITE_USE_TABLE_API=true
VITE_TABLE_API_URL=http://192.168.3.10:8899
